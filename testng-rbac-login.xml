<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  RBAC Full-Login E2E suite — real-browser login journey for every role
  (Electrical Engineer excluded). Needs Chrome.

  Run all:        mvn -o test -DsuiteXmlFile=testng-rbac-login.xml
  Headless (CI):  mvn -B test -DsuiteXmlFile=testng-rbac-login.xml -Dheadless=true
-->
<suite name="eGalvanic RBAC Full-Login E2E" verbose="1">

    <listeners>
        <listener class-name="com.egalvanic.qa.listeners.ConsoleProgressListener"/>
    </listeners>

    <test name="RBAC Full-Login E2E (real browser, per role)">
        <classes>
            <class name="com.egalvanic.qa.testcase.RoleLoginE2ETest"/>
        </classes>
    </test>

</suite>
