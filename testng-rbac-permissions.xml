<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  RBAC permission-contract suite.
  Covers the full production permission matrix
  (testcase/prod_permissions-by-role_*.csv) by asserting each role's live
  /api/auth/me permission set against the matrix.

  Run:  mvn -o test -DsuiteXmlFile=testng-rbac-permissions.xml
-->
<suite name="eGalvanic RBAC Permission Contract" verbose="1">

    <listeners>
        <listener class-name="com.egalvanic.qa.listeners.ConsoleProgressListener"/>
    </listeners>

    <test name="RBAC Permission Contract (API)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.RoleBasedPermissionContractTest"/>
        </classes>
    </test>

    <!-- Per-cell coverage: one test case per role×permission (791 cells). -->
    <test name="RBAC Permission Matrix Cells (API)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.RolePermissionMatrixCellTest"/>
        </classes>
    </test>

    <!-- Action-level enforcement: backend actually denies a work-order edit per role. -->
    <test name="RBAC Work Order Edit Enforcement (API)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.WorkOrderEditEnforcementApiTest"/>
        </classes>
    </test>

    <!-- Action-level enforcement: create/edit Asset(node), Task, Issue per role. -->
    <test name="RBAC Action Enforcement — create/edit (API)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.RoleActionEnforcementApiTest"/>
        </classes>
    </test>

    <!-- Real CRUD contract: privileged role create→edit→delete; asserts the actual 200 async-mutation
         envelope (not just the gate); denied role rejected. -->
    <test name="RBAC CRUD API Contract (real create/edit/delete)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.RoleCrudContractApiTest"/>
        </classes>
    </test>

</suite>
