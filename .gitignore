# Maven build output
target/

# Test output & screenshots
test-output/
# ...EXCEPT the bug-detection report — published to a stable raw GitHub URL
# so claude.ai Routine Runs can fetch it directly. Auto-refreshed by CI.
!test-output/
test-output/screenshots/
test-output/visual-baselines/
test-output/visual-diffs/
test-output/healed-locators.json
test-output/*.png
test-output/*.html
test-output/*.txt
# Allow only the JSON the routine reads:
!test-output/bug-detection-report.json

# Extent reports (generated per run)
reports/

# IDE files
.classpath
.project
.settings/
*.iml
.idea/

# Playwright MCP cache (local debugging artifacts)
.playwright-mcp/
playwright-*.png

# OS files
.DS_Store
Thumbs.db

# Compiled class files
*.class

# Log files
*.log

# Package files
*.jar
*.war
*.zip

# Developer product code — READ-ONLY reference clone (Egalvanic/eg-pz-frontend).
# Lets us browse the frontend source for writing locators. NEVER committed to
# this repo, NEVER pushed to the developer repo. Update with: git -C eg-pz-frontend-reference pull
eg-pz-frontend-reference/

# Non-functional scan outputs (regenerated per run)
security/zap-report.*
perf/k6-summary.json
