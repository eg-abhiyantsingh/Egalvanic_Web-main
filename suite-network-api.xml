<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Network-Captured API Audit (browser network → response validation)" verbose="2">
    <listeners>
        <listener class-name="com.egalvanic.qa.listeners.ConsoleProgressListener"/>
    </listeners>
    <test name="Network API contract">
        <classes>
            <class name="com.egalvanic.qa.testcase.NetworkApiContractTestNG"/>
        </classes>
    </test>
    <!-- Duplicate / redundant API-call detection across modules (report mode; -DSTRICT_DUPLICATE_API=true gates). -->
    <test name="Duplicate API Calls">
        <classes>
            <class name="com.egalvanic.qa.testcase.ApiDuplicateCallTestNG"/>
        </classes>
    </test>
    <!-- UI vs API data-consistency: grid-total refresh determinism + API-vs-UI count (report mode;
         -DSTRICT_DATA_CONSISTENCY=true gates on a reproducible refresh mismatch). -->
    <test name="Data Consistency (UI vs API)">
        <classes>
            <class name="com.egalvanic.qa.testcase.UiApiDataConsistencyTestNG"/>
        </classes>
    </test>
</suite>
