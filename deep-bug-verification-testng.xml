<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Deep Bug Verification Suite — 14 Bug Regression Tests

  Runs one test per bug in docs/changelogs/2026-04-21-full-deep-research-bug-hunt.md
  and eGalvanic_Deep_Bug_Report_20_April_2026.html.

  Each test expects the bug to STILL BE PRESENT. When a bug is fixed in
  production, flip the assertion or remove the @Test — this file then
  becomes a regression gate blocking the bug from reappearing.

  Run: mvn clean test -DsuiteXmlFile=deep-bug-verification-testng.xml
-->
<suite name="eGalvanic Deep Bug Verification Suite (14 Bugs)" verbose="1">

    <listeners>
        <listener class-name="com.egalvanic.qa.listeners.ConsoleProgressListener"/>
    </listeners>

    <test name="Deep Bug Verification — BUG-001..BUG-014 (14 TCs)">
        <classes>
            <class name="com.egalvanic.qa.testcase.DeepBugVerificationTestNG"/>
        </classes>
    </test>

</suite>
