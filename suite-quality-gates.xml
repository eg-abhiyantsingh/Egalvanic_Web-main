<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!--
  Phase 4 cross-cutting quality gates — Accessibility (axe-core WCAG 2 A/AA),
  client-side Performance, Boundary/negative input, and offline Resilience —
  applied across every major module.
  Run: mvn test -DsuiteXmlFile=suite-quality-gates.xml
-->
<suite name="Quality Gates Suite (a11y + perf + boundary + resilience)" verbose="1">
    <listeners>
        <listener class-name="com.egalvanic.qa.listeners.ConsoleProgressListener"/>
    </listeners>
    <test name="Cross-cutting Quality Gates">
        <classes>
            <class name="com.egalvanic.qa.testcase.Phase4QualityGatesTestNG"/>
        </classes>
    </test>
</suite>
