<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Single-slice: work-order edit enforcement (PUT /job/{id} allowed iff jobs.manage). API, no browser.
     mvn test -DsuiteXmlFile=testng-rbac-workorder-api.xml [-Drbac.roles="Project Manager"] -->
<suite name="eGalvanic RBAC — Work Order Edit Enforcement" verbose="1">
    <listeners>
        <listener class-name="com.egalvanic.qa.listeners.ConsoleProgressListener"/>
    </listeners>
    <test name="RBAC Work Order Edit Enforcement (API)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.WorkOrderEditEnforcementApiTest"/>
        </classes>
    </test>
</suite>
