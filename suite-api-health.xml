<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="API Health &amp; Contract (health check + list-API pagination/limit/filter contract)" verbose="2">
    <listeners>
        <listener class-name="com.egalvanic.qa.listeners.ConsoleProgressListener"/>
    </listeners>
    <!-- Health monitor: ~50-endpoint pass/warn/fail + recommendations (incl. pagination advisories). -->
    <test name="API Health Check">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.ApiHealthCheckApiTest"/>
        </classes>
    </test>
    <!-- Enforcing pagination/limit/default/filter contract (report mode; -DSTRICT_LIST_API_CONTRACT=true gates). -->
    <test name="List-API Pagination Contract">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.ListApiContractApiTest"/>
        </classes>
    </test>
    <!-- Pagination SEMANTICS: disjoint pages, stable ordering, beyond-end page, abusive params,
         total consistency — 7 contract endpoints + sessions/workorders (~800-row collections).
         5xx / semantic violations on paginating endpoints hard-fail; unpaginated endpoints WARN+skip
         (same -DSTRICT_LIST_API_CONTRACT=true escalation as the contract audit). -->
    <test name="List-API Pagination Behavior">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.PaginationBehaviorApiTest"/>
        </classes>
    </test>
    <!-- Error-status contracts: unknown-resource 404s, malformed-input never-5xx, unauth 401 gate,
         + a repeated-sample "502 detector" over the critical-path panel (catches the intermittent
         backend degradation signature of the 2026-07-03 incident). GET-only, zero mutation risk.
         Soft gaps (200-instead-of-404/401) report to reports/error-contract-report.md;
         -DSTRICT_ERROR_CONTRACT=true escalates them. -->
    <test name="API Error Contract + 502 Detector">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.ErrorContractApiTest"/>
        </classes>
    </test>
    <!-- Transport contract: Content-Type (JSON vs SPA-shell 200s), nosniff/HSTS/no-store headers,
         evil-Origin CORS reflection (credentialed reflection = only hard fail), version leakage.
         GET-only, zero mutation risk. Soft gaps → reports/security-headers-report.md;
         -DSTRICT_SECURITY_CONTRACT=true escalates them. -->
    <test name="API Transport Contract (headers/CORS/content-type)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.SecurityHeadersApiTest"/>
        </classes>
    </test>
    <!-- FULL catalog: every operation in /api/swagger.json (spec-driven, ~973 ops). GET authed
         (random-UUID path params); POST/PUT/PATCH/DELETE probed UNAUTHENTICATED with an empty body
         (auth-gate check only — zero mutation risk). Report mode: only a genuine outage fails. -->
    <test name="API Full Catalog (spec-driven)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.ApiFullCatalogHealthApiTest"/>
        </classes>
    </test>
    <!-- Filter / search / list-vs-detail CONSISTENCY on POST /v2/issues/list (the one paginated+
         filterable list API). READ-ONLY. Correctness invariants (filter purity, search finds-what-
         exists, pagination disjoint, list==detail) hard-fail (they hold live → regression guard);
         array-valued-filter 500+SQL-leak reports as DEFECT, -DSTRICT_CONSISTENCY_CONTRACT=true gates. -->
    <test name="API Filter/Search Consistency">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.FilterSearchConsistencyApiTest"/>
        </classes>
    </test>
    <!-- ── Authenticated CRUD / write-path contracts ──────────────────────────────────────────
         The classes below MUTATE, but ONLY on the dedicated sandbox SLD named "test site for api
         check" (each resolves it by name and SKIPS if absent — never a real site), every record
         carries a class marker (ApiCrud_/ApiInval_/ApiMut_), and each self-cleans in @AfterClass +
         sweeps strays from any prior crashed run. Run sequentially (default) so they never race on
         the sandbox. All are GREEN by default; the STRICT_* gates escalate the backend findings. -->

    <!-- CRUD lifecycle: authenticated create→read→update→(soft)delete round-trips for task / issue /
         building, asserting each step persists and delists. Hard-fails on a broken round-trip. -->
    <test name="API CRUD Lifecycle">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.CrudLifecycleApiTest"/>
        </classes>
    </test>
    <!-- Input validation: malformed/negative authenticated bodies must yield 4xx (never 5xx) and must
         not leak DB/stack internals. Report mode; -DSTRICT_INPUT_VALIDATION=true escalates the real
         backend defects (task/create + /v2/issues/list 500 + psycopg2 leakage, curl-verified). -->
    <test name="API Input Validation">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.InputValidationApiTest"/>
        </classes>
    </test>
    <!-- Mutation semantics: async queue eventual-convergence vs synchronous x-direct-write, delete
         idempotency, DELETE media-type contract. Behaviours hold live → hard-fail as regression guard. -->
    <test name="API Mutation Semantics">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.MutationSemanticsApiTest"/>
        </classes>
    </test>
</suite>
