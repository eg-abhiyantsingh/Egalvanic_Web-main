<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!-- data-provider-thread-count=6: fans out ApiFullCatalogHealthApiTest's ~973-op parallel @DataProvider
     across 6 threads (the dominant runtime cost → ~2x+ faster). Kept at 6 (not TestNG's default 10) because
     the QA host is 502/latency-prone and a larger burst can raise ambient 502s. Suite stays SEQUENTIAL
     (no parallel="tests") so the 3 sandbox-mutating classes never overlap and authToken is written serially. -->
<suite name="API Health &amp; Contract (health check + list-API pagination/limit/filter contract)" verbose="2" data-provider-thread-count="6">
    <listeners>
        <listener class-name="com.egalvanic.qa.listeners.ConsoleProgressListener"/>
    </listeners>
    <!-- Health monitor: ~50-endpoint pass/warn/fail + recommendations (incl. pagination advisories). -->
    <test name="API Health Check">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.ApiHealthCheckApiTest"/>
        </classes>
    </test>
    <!-- Enforcing pagination/limit/default/filter contract (report mode; -DSTRICT_LIST_API_CONTRACT=true gates). -->
    <test name="List-API Pagination Contract">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.ListApiContractApiTest"/>
        </classes>
    </test>
    <!-- CATALOG-WIDE pagination: the curated contract above covers 7 known-good endpoints; this
         applies the SAME contract to EVERY collection the live swagger spec exposes (spec-driven,
         so new list endpoints are audited automatically). ~60 collections incl. large ones the
         curated set never reached (eqp-lib/manufacturers, opportunity/, attachment/, contact/,
         account/, reporting/*, mutations…). GET-only; report mode (green by default);
         -DSTRICT_LIST_API_CONTRACT=true escalates violations (same gate as the curated test). -->
    <test name="List-API Pagination Catalog (spec-driven)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.ListApiCatalogAuditTest"/>
        </classes>
    </test>
    <!-- Pagination SEMANTICS: disjoint pages, stable ordering, beyond-end page, abusive params,
         total consistency — 7 contract endpoints + sessions/workorders (~800-row collections).
         5xx / semantic violations on paginating endpoints hard-fail; unpaginated endpoints WARN+skip
         (same -DSTRICT_LIST_API_CONTRACT=true escalation as the contract audit). -->
    <test name="List-API Pagination Behavior">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.PaginationBehaviorApiTest"/>
        </classes>
    </test>
    <!-- Error-status contracts: unknown-resource 404s, malformed-input never-5xx, unauth 401 gate,
         + a repeated-sample "502 detector" over the critical-path panel (catches the intermittent
         backend degradation signature of the 2026-07-03 incident). GET-only, zero mutation risk.
         Soft gaps (200-instead-of-404/401) report to reports/error-contract-report.md;
         -DSTRICT_ERROR_CONTRACT=true escalates them. -->
    <test name="API Error Contract + 502 Detector">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.ErrorContractApiTest"/>
        </classes>
    </test>
    <!-- All-pages 502 sweep: every app page's live-captured backing endpoints swept repeatedly for
         502/5xx/timeout, attributed to the page a user would see fail. Report-mode → reports/
         all-pages-502-report.md; -DSTRICT_ALL_PAGES=true escalates. GET + the list POSTs pages use. -->
    <test name="API All-Pages 502 Sweep">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.AllPagesStabilityApiTest"/>
        </classes>
    </test>
    <!-- Transport contract: Content-Type (JSON vs SPA-shell 200s), nosniff/HSTS/no-store headers,
         evil-Origin CORS reflection (credentialed reflection = only hard fail), version leakage.
         GET-only, zero mutation risk. Soft gaps → reports/security-headers-report.md;
         -DSTRICT_SECURITY_CONTRACT=true escalates them. -->
    <test name="API Transport Contract (headers/CORS/content-type)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.SecurityHeadersApiTest"/>
        </classes>
    </test>
    <!-- FULL catalog: every operation in /api/swagger.json (spec-driven, ~973 ops). GET authed
         (random-UUID path params); POST/PUT/PATCH/DELETE probed UNAUTHENTICATED with an empty body
         (auth-gate check only — zero mutation risk). Report mode: only a genuine outage fails. -->
    <test name="API Full Catalog (spec-driven)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.ApiFullCatalogHealthApiTest"/>
        </classes>
    </test>
    <!-- AGENTS family DEEP contract (largest catalog slice, 105 ops). Hard-asserts the agent-token
         privilege boundary on every /agents/* data endpoint (GET rejects a user token; mutations
         reject unauthenticated calls — a 2xx-with-data would be a boundary breach) + the /agent/health
         SDK/service contract. GET (user token) + unauth-empty mutations = zero mutation risk; the ~14
         /agent/* runtime proxies (LLM/sandbox) are intentionally excluded (proven in the coverage test). -->
    <test name="API Agents Contract (agent-token boundary + health)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.AgentsContractApiTest"/>
        </classes>
    </test>
    <!-- Spec-level duplicate-endpoint audit: dash/underscore twins (planned-workorder-line vs
         planned_workorder_line confirmed live), trailing-slash twins, singular/plural roots,
         v1/v2 overlaps. Pure spec analysis (only fetches swagger.json). Report mode;
         -DSTRICT_SPEC_HYGIENE=true gates exact twins. Runtime duplicate CALLS stay in Suite 2's
         browser-driven ApiDuplicateCallTestNG (needs Chrome). -->
    <test name="API Duplicate-Endpoint Audit (spec-driven)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.DuplicateApiAuditTest"/>
        </classes>
    </test>
    <!-- IR/FLIR photo pipeline: auth-gates on every ir_photo/ir_session mutation + ir_session read
         models, PLUS a contract-WATCH for the upcoming FLIR-IND visual-generation endpoint (SKIPs
         with a clear message until it appears in swagger, then auto-activates its validation
         contract: unauth 401, photo_type!=FLIR-IND -> 400, missing params -> 4xx). -->
    <test name="API IR/FLIR Photo Pipeline Contract">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.IrFlirContractApiTest"/>
        </classes>
    </test>
    <!-- SLD V3 load performance + payload benchmark (QA coverage for the SLD-payload-optimization ticket):
         per-SLD v3 load latency, total payload, per-node node_terminals total (~8.6MB bottleneck on 8k+ nodes),
         dominant payload keys, and a v2 before/after delta. GET-only, report mode; -DSTRICT_SLD_PERF=true gates
         latency/size-target misses; a 5xx / structure regression fails regardless. Sample via -Dsld.benchmark.sample. -->
    <test name="API SLD V3 Payload Benchmark">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.SldV3PayloadBenchmarkApiTest"/>
        </classes>
    </test>
    <!-- EVIDENCE capture: makes the live call for every issue class (invalid-request 500+SQL leak,
         502/availability, performance, pagination, SPA-fallback, auth-gate, agent-token) and records
         the full HTTP transaction to reports/api-evidence.json. Rendered as visual "capture cards"
         (the REST equivalent of a screenshot) in the consolidated report. Report-only, never fails. -->
    <test name="API Evidence Capture">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.ApiEvidenceCaptureApiTest"/>
        </classes>
    </test>
    <!-- Filter / search / list-vs-detail CONSISTENCY on POST /v2/issues/list (the one paginated+
         filterable list API). READ-ONLY. Correctness invariants (filter purity, search finds-what-
         exists, pagination disjoint, list==detail) hard-fail (they hold live → regression guard);
         array-valued-filter 500+SQL-leak reports as DEFECT, -DSTRICT_CONSISTENCY_CONTRACT=true gates. -->
    <test name="API Filter/Search Consistency">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.FilterSearchConsistencyApiTest"/>
        </classes>
    </test>
    <!-- ── Authenticated CRUD / write-path contracts ──────────────────────────────────────────
         The classes below MUTATE, but ONLY on the dedicated sandbox SLD named "test site for api
         check" (each resolves it by name and SKIPS if absent — never a real site), every record
         carries a class marker (ApiCrud_/ApiInval_/ApiMut_), and each self-cleans in @AfterClass +
         sweeps strays from any prior crashed run. Run sequentially (default) so they never race on
         the sandbox. All are GREEN by default; the STRICT_* gates escalate the backend findings. -->

    <!-- CRUD lifecycle: authenticated create→read→update→(soft)delete round-trips for task / issue /
         building, asserting each step persists and delists. Hard-fails on a broken round-trip. -->
    <test name="API CRUD Lifecycle">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.CrudLifecycleApiTest"/>
        </classes>
    </test>
    <!-- Input validation: malformed/negative authenticated bodies must yield 4xx (never 5xx) and must
         not leak DB/stack internals. Report mode; -DSTRICT_INPUT_VALIDATION=true escalates the real
         backend defects (task/create + /v2/issues/list 500 + psycopg2 leakage, curl-verified). -->
    <test name="API Input Validation">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.InputValidationApiTest"/>
        </classes>
    </test>
    <!-- Mutation semantics: async queue eventual-convergence vs synchronous x-direct-write, delete
         idempotency, DELETE media-type contract. Behaviours hold live → hard-fail as regression guard. -->
    <test name="API Mutation Semantics">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.MutationSemanticsApiTest"/>
        </classes>
    </test>
    <!-- Sentry 502 correlation: pulls the org's unresolved 502 issues (last 24h) from Sentry's REST
         API — the inside view pairing with the outside sweeps. Needs SENTRY_AUTH_TOKEN (skips with
         setup instructions when absent). -DSTRICT_SENTRY_502=true escalates. -->
    <test name="API Sentry 502 Correlation">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.Sentry502CorrelationApiTest"/>
        </classes>
    </test>
    <!-- Browser 502 sweep with SCREENSHOT evidence (needs Chrome — CI installs it): logs in once,
         walks every sidebar page via client-side routing, records any 5xx/502 the page's API calls
         return, and screenshots the page as user-visible evidence (reports/evidence/*.png, embedded
         in the consolidated report). Report-mode; -DSTRICT_PAGE_502=true escalates. LAST so the
         API-only areas never wait on a browser session. -->
    <test name="Page 502 Screenshot Sweep (browser)">
        <classes>
            <class name="com.egalvanic.qa.testcase.Page502ScreenshotSweepTestNG"/>
        </classes>
    </test>
</suite>
