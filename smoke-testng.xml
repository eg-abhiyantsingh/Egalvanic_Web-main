<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Smoke-Test-Suite" verbose="0">

    <listeners>
        <listener class-name="com.egalvanic.qa.listeners.ConsoleProgressListener"/>
    </listeners>

    <test name="Auth-Login-Smoke">
        <classes>
            <class name="com.egalvanic.qa.testcase.AuthSmokeTestNG"/>
        </classes>
    </test>

    <test name="Site-Selection-Smoke">
        <classes>
            <class name="com.egalvanic.qa.testcase.SiteSelectionSmokeTestNG"/>
        </classes>
    </test>

    <test name="Asset-CRUD-Smoke">
        <classes>
            <class name="com.egalvanic.qa.testcase.AssetSmokeTestNG"/>
        </classes>
    </test>

    <test name="Connection-CRUD-Smoke">
        <classes>
            <class name="com.egalvanic.qa.testcase.ConnectionSmokeTestNG"/>
        </classes>
    </test>

    <test name="Location-CRUD-Smoke">
        <classes>
            <class name="com.egalvanic.qa.testcase.LocationSmokeTestNG"/>
        </classes>
    </test>

</suite>
