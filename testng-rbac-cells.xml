<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Single-slice: per-cell role×permission coverage (791 cells). API, no browser.
     mvn test -DsuiteXmlFile=testng-rbac-cells.xml [-Drbac.roles="Project Manager"] -->
<suite name="eGalvanic RBAC — Permission Matrix Cells" verbose="1">
    <listeners>
        <listener class-name="com.egalvanic.qa.listeners.ConsoleProgressListener"/>
    </listeners>
    <test name="RBAC Permission Matrix Cells (API)">
        <classes>
            <class name="com.egalvanic.qa.testcase.api.RolePermissionMatrixCellTest"/>
        </classes>
    </test>
</suite>
