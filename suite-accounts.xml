<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Accounts [SALES] — first dedicated module suite for /accounts.
  Read / columns / search + create-dialog VALIDATION (never submits — the create form
  collects a Subdomain that may provision a tenant) + account detail + Contacts tab +
  confirmation-gated delete (cancelled). API BAC tripwire for the flat /accounts/ endpoint.

  Default run = the FUNCTIONAL GATE: excludes the `known-product-bug` group so the build is
  green on real behaviour and goes RED only on a regression. Excluded tests are intentional
  RED tripwires for filed product bugs (BUG-A crash, BUG-B WCAG, BUG-E flat-endpoint auth —
  see BUGS.md); their assertions are NOT weakened, just quarantined out of the gate.

  Functional gate:        mvn test -DsuiteXmlFile=suite-accounts.xml
  Exercise the tripwires: mvn test -Dtest=AccountsTestNG -Dgroups=known-product-bug
-->
<suite name="Accounts Suite (CRUD validation + detail/contacts + a11y + API)" verbose="1">
    <listeners>
        <listener class-name="com.egalvanic.qa.listeners.ConsoleProgressListener"/>
    </listeners>
    <test name="Accounts [SALES]">
        <groups>
            <run>
                <exclude name="known-product-bug"/>
            </run>
        </groups>
        <classes>
            <class name="com.egalvanic.qa.testcase.AccountsTestNG"/>
        </classes>
    </test>
</suite>
